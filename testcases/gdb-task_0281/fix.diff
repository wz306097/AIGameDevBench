diff --git a/scenes/card_ui/card_states/card_base_state.gd b/scenes/card_ui/card_states/card_base_state.gd
index eedf3f4..ccd6bcc 100644
--- a/scenes/card_ui/card_states/card_base_state.gd
+++ b/scenes/card_ui/card_states/card_base_state.gd
@@ -1 +1,17 @@
 extends "res://scenes/card_ui/card_states/card_state.gd"
+
+
+func enter() -> void:
+	if card_ui.tween and card_ui.tween.is_running():
+		card_ui.tween.kill()
+
+	card_ui.state_label.text = "Base"
+	card_ui.reparent_requested.emit(card_ui)
+	card_ui.drop_point_detector.monitoring = false
+	card_ui.pivot_offset = Vector2.ZERO
+
+
+func on_gui_input(event: InputEvent) -> void:
+	if event.is_action_pressed("left_mouse"):
+		card_ui.pivot_offset = event.global_position - card_ui.global_position
+		transition_requested.emit(self, State.CLICKED)
