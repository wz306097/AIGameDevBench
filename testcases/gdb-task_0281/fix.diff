diff --git a/scenes/card_ui/card_states/card_dragging_state.gd b/scenes/card_ui/card_states/card_dragging_state.gd
index b9e8d07..71af96b 100644
--- a/scenes/card_ui/card_states/card_dragging_state.gd
+++ b/scenes/card_ui/card_states/card_dragging_state.gd
@@ -1,3 +1,27 @@
 extends "res://scenes/card_ui/card_states/card_state.gd"
 
 const DRAG_MINIMUM_THRESHOLD := 0.04
+
+var minimum_drag_time_elapsed := false
+
+
+func enter() -> void:
+	card_ui.state_label.text = "Dragging"
+
+	var ui_layer = card_ui.home_parent.get_parent()
+	if ui_layer:
+		card_ui.reparent(ui_layer)
+
+	minimum_drag_time_elapsed = false
+	var threshold_timer := get_tree().create_timer(DRAG_MINIMUM_THRESHOLD, false)
+	threshold_timer.timeout.connect(func(): minimum_drag_time_elapsed = true)
+
+
+func on_input(event: InputEvent) -> void:
+	if event is InputEventMouseMotion:
+		card_ui.global_position = event.global_position - card_ui.pivot_offset
+
+	if event.is_action_pressed("right_mouse"):
+		transition_requested.emit(self, State.BASE)
+	elif minimum_drag_time_elapsed and event.is_action_released("left_mouse"):
+		transition_requested.emit(self, State.RELEASED)
diff --git a/scenes/card_ui/card_states/card_released_state.gd b/scenes/card_ui/card_states/card_released_state.gd
index eedf3f4..299a061 100644
--- a/scenes/card_ui/card_states/card_released_state.gd
+++ b/scenes/card_ui/card_states/card_released_state.gd
@@ -1 +1,19 @@
 extends "res://scenes/card_ui/card_states/card_state.gd"
+
+var played := false
+
+
+func enter() -> void:
+	card_ui.state_label.text = "Released"
+	played = false
+
+	if not card_ui.targets.is_empty():
+		played = true
+		card_ui.play()
+
+
+func on_input(_event: InputEvent) -> void:
+	if played:
+		return
+
+	transition_requested.emit(self, State.BASE)
